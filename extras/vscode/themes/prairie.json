    "menu.separatorBackground": "#006aad"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#006aad",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#3b7b31",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#190d00"
      }
    },
    {
      "name": "Boolean",
      "scope": [
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#190d00"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "constant.language"
      ],
      "settings": {
        "foreground": "#190d00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#190d00",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#190d00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#190d00",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#190d00"
      }
    },
    {
      "name": "Type",
      "scope": [
        "entity.name.type",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#190d00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Class",
      "scope": [
        "entity.name.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#190d00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#190d00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#190d00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Special",
      "scope": [
        "constant.character.escape",
        "constant.other"
      ],
      "settings": {
        "foreground": "#190d00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#190d00"
      }
    },
    {
      "name": "Link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#006aad",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Heading",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#190d00",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Error",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ff3333",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Warning",
      "scope": [
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#a19751",
        "fontStyle": "italic"
      }
    },
    {
      "name": "TODO",
      "scope": [
        "keyword.other.todo",
        "comment.keyword.todo"
      ],
      "settings": {
        "foreground": "#006aad",
        "fontStyle": "bold italic"
      }
    }
  ]
}
