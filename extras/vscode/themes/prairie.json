    "editorWhitespace.foreground": "#958272",
    "statusBar.background": "#ffe699",
    "statusBar.foreground": "#190d00",
    "statusBar.noFolderBackground": "#ffe699",
    "statusBar.debuggingBackground": "#ff7347",
    "activityBar.background": "#ffe699",
    "activityBar.foreground": "#190d00",
    "activityBar.inactiveForeground": "#958272",
    "sideBar.background": "#fff4cc",
