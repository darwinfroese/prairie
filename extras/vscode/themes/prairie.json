    "inputOption.activeBorder": "#006aad",
    "button.background": "#006aad",
    "button.foreground": "#fff4cc",
    "dropdown.background": "#fff4cc",
    "dropdown.border": "#006aad",
    "panel.background": "#fff4cc",
    "panel.border": "#006aad",
    "terminal.background": "#fff4cc",
    "terminal.foreground": "#190d00",
    "terminal.ansiBlack": "#190d00",
    "terminal.ansiRed": "#ff3333",
    "terminal.ansiGreen": "#3b7b31",
    "terminal.ansiYellow": "#a19751",
    "terminal.ansiBlue": "#006aad",
