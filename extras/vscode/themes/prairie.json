    "peekView.border": "#006aad",
    "peekViewEditor.background": "#fff4cc",
    "peekViewResult.background": "#ffe699",
    "peekViewTitle.background": "#ffe699",
    "notifications.background": "#fff4cc",
    "notifications.foreground": "#190d00",
